{
  "name": "schoolmule-backend",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "test": "npm run test:unit ; npm run test:integration",
    "test:unit": "jest --config __tests__/jest.unit.config.js",
    "test:integration": "jest --config __tests__/jest.integration.config.js --runInBand",
    "test:unit:watch": "jest --config __tests__/jest.unit.config.js --watch",
    "test:unit:coverage": "jest --config __tests__/jest.unit.config.js --coverage",
    "test:integration:coverage": "jest --config __tests__/jest.integration.config.js --runInBand --coverage",
    "test:ci": "jest --config jest.config.js --ci --coverage --runInBand",
    "docker:test:up": "docker compose -f docker-compose.test.yml up -d --wait",
    "docker:test:down": "docker compose -f docker-compose.test.yml down -v",
    "dev": "nodemon server.js",
    "start": "node server.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/husaab/schoolmule-backend.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/husaab/schoolmule-backend/issues"
  },
  "homepage": "https://github.com/husaab/schoolmule-backend#readme",
  "description": "",
  "dependencies": {
    "@supabase/supabase-js": "^2.50.0",
    "bcrypt": "^6.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "ejs": "^3.1.10",
    "exceljs": "^4.4.0",
    "express": "^5.1.0",
    "express-rate-limit": "^7.5.0",
    "express-validator": "^7.2.1",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.0.2",
    "nodemon": "^3.1.10",
    "pdf-lib": "^1.17.1",
    "pg": "^8.16.0",
    "pino": "^9.7.0",
    "pino-http": "^11.0.0",
    "puppeteer": "^24.10.0",
    "resend": "^4.5.1",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "pino-pretty": "^13.1.3",
    "supertest": "^7.0.0"
  }
}
